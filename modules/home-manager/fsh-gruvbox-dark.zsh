zstyle :plugin:fast-syntax-highlighting theme gruvbox-dark

: ${FAST_HIGHLIGHT_STYLES[default]:=none}

: ${FAST_HIGHLIGHT_STYLES[unknown-token]:=fg=#fb4934,bold}
: ${FAST_HIGHLIGHT_STYLES[matherr]:=fg=#fb4934}
: ${FAST_HIGHLIGHT_STYLES[incorrect-subtle]:=fg=#fb4934}

: ${FAST_HIGHLIGHT_STYLES[reserved-word]:=fg=#fabd2f}
: ${FAST_HIGHLIGHT_STYLES[subcommand]:=fg=#fabd2f}

: ${FAST_HIGHLIGHT_STYLES[command]:=fg=#b8bb26}
: ${FAST_HIGHLIGHT_STYLES[builtin]:=fg=#b8bb26}
: ${FAST_HIGHLIGHT_STYLES[function]:=fg=#b8bb26}
: ${FAST_HIGHLIGHT_STYLES[alias]:=fg=#b8bb26}
: ${FAST_HIGHLIGHT_STYLES[suffix-alias]:=fg=#b8bb26}
: ${FAST_HIGHLIGHT_STYLES[global-alias]:=fg=#8ec07c}
: ${FAST_HIGHLIGHT_STYLES[precommand]:=fg=#b8bb26}
: ${FAST_HIGHLIGHT_STYLES[hashed-command]:=fg=#b8bb26}
: ${FAST_HIGHLIGHT_STYLES[commandseparator]:=none}

: ${FAST_HIGHLIGHT_STYLES[path]:=fg=#d3869b}
: ${FAST_HIGHLIGHT_STYLES[path-to-dir]:=fg=#d3869b,underline}
: ${FAST_HIGHLIGHT_STYLES[path_pathseparator]:=}

: ${FAST_HIGHLIGHT_STYLES[globbing]:=fg=#83a598,bold}
: ${FAST_HIGHLIGHT_STYLES[globbing-ext]:=fg=#d3869b}
: ${FAST_HIGHLIGHT_STYLES[history-expansion]:=fg=#83a598,bold}

: ${FAST_HIGHLIGHT_STYLES[single-hyphen-option]:=fg=#8ec07c}
: ${FAST_HIGHLIGHT_STYLES[double-hyphen-option]:=fg=#8ec07c}

: ${FAST_HIGHLIGHT_STYLES[back-quoted-argument]:=none}
: ${FAST_HIGHLIGHT_STYLES[single-quoted-argument]:=fg=#fabd2f}
: ${FAST_HIGHLIGHT_STYLES[double-quoted-argument]:=fg=#fabd2f}
: ${FAST_HIGHLIGHT_STYLES[dollar-quoted-argument]:=fg=#fabd2f}
: ${FAST_HIGHLIGHT_STYLES[back-or-dollar-double-quoted-argument]:=fg=#8ec07c}
: ${FAST_HIGHLIGHT_STYLES[back-dollar-quoted-argument]:=fg=#8ec07c}

: ${FAST_HIGHLIGHT_STYLES[assign]:=none}
: ${FAST_HIGHLIGHT_STYLES[assign-array-bracket]:=fg=#b8bb26}

: ${FAST_HIGHLIGHT_STYLES[redirection]:=fg=#fe8019}
: ${FAST_HIGHLIGHT_STYLES[exec-descriptor]:=fg=#fabd2f,bold}

: ${FAST_HIGHLIGHT_STYLES[comment]:=fg=#928374}

: ${FAST_HIGHLIGHT_STYLES[variable]:=fg=#83a598}
: ${FAST_HIGHLIGHT_STYLES[mathvar]:=fg=#83a598,bold}
: ${FAST_HIGHLIGHT_STYLES[mathnum]:=fg=#d3869b}

: ${FAST_HIGHLIGHT_STYLES[for-loop-variable]:=none}
: ${FAST_HIGHLIGHT_STYLES[for-loop-number]:=fg=#d3869b}
: ${FAST_HIGHLIGHT_STYLES[for-loop-operator]:=fg=#fabd2f}
: ${FAST_HIGHLIGHT_STYLES[for-loop-separator]:=fg=#fabd2f,bold}

: ${FAST_HIGHLIGHT_STYLES[here-string-tri]:=fg=#fabd2f}
: ${FAST_HIGHLIGHT_STYLES[here-string-text]:=bg=#3c3836}
: ${FAST_HIGHLIGHT_STYLES[here-string-var]:=fg=#8ec07c,bg=#3c3836}

: ${FAST_HIGHLIGHT_STYLES[case-input]:=fg=#b8bb26}
: ${FAST_HIGHLIGHT_STYLES[case-parentheses]:=fg=#fabd2f}
: ${FAST_HIGHLIGHT_STYLES[case-condition]:=bg=#3c3836}

: ${FAST_HIGHLIGHT_STYLES[correct-subtle]:=fg=#928374}
: ${FAST_HIGHLIGHT_STYLES[subtle-separator]:=fg=#b8bb26}
: ${FAST_HIGHLIGHT_STYLES[subtle-bg]:=bg=#3c3836}

: ${FAST_HIGHLIGHT_STYLES[paired-bracket]:=bg=#504945}
: ${FAST_HIGHLIGHT_STYLES[bracket-level-1]:=fg=#b8bb26,bold}
: ${FAST_HIGHLIGHT_STYLES[bracket-level-2]:=fg=#fabd2f,bold}
: ${FAST_HIGHLIGHT_STYLES[bracket-level-3]:=fg=#8ec07c,bold}
: ${FAST_HIGHLIGHT_STYLES[single-sq-bracket]:=fg=#b8bb26}
: ${FAST_HIGHLIGHT_STYLES[double-sq-bracket]:=fg=#b8bb26}
: ${FAST_HIGHLIGHT_STYLES[double-paren]:=fg=#fabd2f}

: ${FAST_HIGHLIGHT_STYLES[recursive-base]:=fg=#fabd2f,bold}

: ${FAST_HIGHLIGHT_STYLES[optarg-string]:=fg=#fabd2f}
: ${FAST_HIGHLIGHT_STYLES[optarg-number]:=fg=#d3869b}
