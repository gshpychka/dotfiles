+/*
+ * Handle OSC 9. Only the ConEmu/Ghostty progress protocol (OSC 9 ; 4) is
+ * understood; tmux has no progress state of its own, so rather than dropping
+ * the sequence it is forwarded verbatim to the outer terminal (only when the
+ * pane is visible). Other OSC 9 uses (e.g. notifications) are ignored as
+ * before.
+ */
+static void
+input_osc_9(struct input_ctx *ictx, const char *p)
+{
+	struct screen_write_ctx	*sctx = &ictx->ctx;
+	char			*out;
+	int			 outlen;
+
+	if (p[0] != '4' || (p[1] != ';' && p[1] != '\0'))
+		return;
+
+	outlen = xasprintf(&out, "\033]9;%s\033\\", p);
+	screen_write_rawstring(sctx, (u_char *)out, outlen, 0);
+	free(out);
+}
